DISCORD_TOKEN=your_bot_token
DISCORD_GUILD_ID=123456789
DATABASE_URL=postgresql+asyncpg://bot:password@postgres:5432/voice_bot
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=your_secret_for_jwt
SCHEDULER_CHECK_INTERVAL=30
DEFAULT_TIMEZONE=Europe/Moscow
RATE_LIMIT_ACTIONS_PER_MINUTE=60

# PostgreSQL (used by postgres service in docker-compose)
POSTGRES_USER=bot
POSTGRES_PASSWORD=password
POSTGRES_DB=voice_bot

# Discord OAuth2
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost/auth/discord/callback

# Dashboard JWT (run: openssl rand -hex 32)
JWT_SECRET=
JWT_EXPIRE_HOURS=24

# Comma-separated Discord user IDs allowed to access dashboard
ALLOWED_DISCORD_IDS=123456789,987654321
